{
  "expo": {
    "name": "Kotizy",
    "slug": "kotizy",
    "owner": "kenams",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "kotizy",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080b07"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kahdigital.kotizy"
    },
    "android": {
      "package": "com.kahdigital.kotizy",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080b07"
      },
      "edgeToEdgeEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "projectName": "Kotizy",
      "eas": {
        "projectId": "5e1b5c7a-7b38-4f86-97ff-2e23614f0f95"
      }
    },
    "plugins": [
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.kahdigital.kotizy"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#22c55e",
          "sounds": []
        }
      ]
    ]
  }
}
