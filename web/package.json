{
  "name": "tontineapp-web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3021",
    "dev:local": "node scripts/dev-server.mjs",
    "build": "prisma generate && next build",
    "start": "next start -p 3021",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:generate:postgres": "prisma generate --schema prisma/schema.postgres.prisma",
    "prisma:push": "prisma db push",
    "prisma:push:postgres": "prisma db push --schema prisma/schema.postgres.prisma",
    "seed": "tsx prisma/seed.ts",
    "db:setup": "prisma db push && tsx prisma/seed.ts",
    "db:setup:postgres": "prisma db push --schema prisma/schema.postgres.prisma && tsx prisma/seed.ts",
    "db:reset": "npm run db:setup"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "bcryptjs": "^2.4.3",
    "framer-motion": "^12.12.1",
    "lucide-react": "^0.468.0",
    "next": "^15.3.3",
    "next-themes": "^0.4.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "stripe": "^22.2.0",
    "zod": "^3.25.32"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.21",
    "@types/react": "^19.0.14",
    "@types/react-dom": "^19.0.6",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "prisma": "^6.8.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
